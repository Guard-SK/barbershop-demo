---
import { useTranslations } from '../i18n/utils'

interface Props {
    lang: 'sk' | 'en'
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section
    class="relative py-32 bg-black overflow-hidden flex items-center justify-center"
>
    <!-- Dynamic Background -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute inset-0 bg-neutral-900"></div>
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-luxury-gold/10 blur-[100px] rounded-full animate-pulse-slow"
        >
        </div>
        <div
            class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_center,transparent_0%,#000000_100%)]"
        >
        </div>
    </div>

    <div class="relative z-10 text-center max-w-4xl mx-auto px-6">
        <p
            class="text-luxury-gold uppercase tracking-[0.3em] text-sm font-bold mb-6 animate-fade-in-up"
        >
            {lang === 'sk' ? 'Pripravený na zmenu?' : 'Ready for a change?'}
        </p>

        <h2
            class="text-5xl md:text-7xl font-black text-white mb-12 uppercase tracking-tighter leading-tight animate-fade-in-up delay-100"
        >
            {t('cta.title')}<br />
            <span
                class="text-transparent bg-clip-text bg-gradient-to-r from-white via-neutral-200 to-neutral-500"
                >{t('cta.subtitle')}</span
            >
        </h2>

        <!-- Magnetic Button Container -->
        <div class="relative inline-block group animate-fade-in-up delay-200">
            <div
                class="absolute inset-0 bg-luxury-gold blur-xl opacity-30 group-hover:opacity-70 transition-opacity duration-500 rounded-full"
            >
            </div>
            <a
                href="https://www.bookio.com/sk"
                target="_blank"
                class="relative block px-12 py-6 bg-luxury-gold hover:bg-white text-black font-black uppercase tracking-widest text-lg transition-all duration-300 rounded-full hover:scale-105 active:scale-95"
            >
                {t('cta.button')}
            </a>
        </div>

        <p
            class="mt-8 text-neutral-500 text-sm font-mono animate-fade-in-up delay-300"
        >
            {t('cta.scarcity')}
        </p>
    </div>
</section>

<style>
    @keyframes pulse-slow {
        0%,
        100% {
            opacity: 0.3;
            transform: translate(-50%, -50%) scale(1);
        }
        50% {
            opacity: 0.6;
            transform: translate(-50%, -50%) scale(1.1);
        }
    }
    .animate-pulse-slow {
        animation: pulse-slow 8s ease-in-out infinite;
    }
</style>
