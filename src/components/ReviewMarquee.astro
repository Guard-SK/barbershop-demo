---
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';

interface Props {
    lang: 'sk' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const reviews = await getCollection('reviews', ({ data }) => data.lang === lang);
// Duplicate reviews to create seamless loop
const allReviews = [...reviews, ...reviews, ...reviews];
---

<section id="recenzie" class="py-24 bg-neutral-900 border-t border-white/5 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 mb-12 text-center">
        <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white mb-6">
            {lang === 'sk' ? 'Čo o nás hovoria' : 'What they say about us'}
        </h2>
        
        <!-- Google Badge -->
        <div class="inline-flex items-center gap-4 bg-white/5 border border-white/10 rounded-full px-6 py-3 backdrop-blur-sm">
            <svg class="w-6 h-6" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                <path fill="none" d="M0 0h48v48H0z"/>
            </svg>
            <div class="flex flex-col items-start">
                <div class="flex gap-1 text-[#FBBC05]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <span class="text-xs font-bold text-white uppercase tracking-wider">4.9/5 na Google Maps</span>
            </div>
        </div>
    </div>

    <!-- Marquee Container -->
    <div class="relative w-full mb-12">
        <!-- Fade Edges -->
        <div class="absolute left-0 top-0 bottom-0 w-24 md:w-64 bg-gradient-to-r from-neutral-900 to-transparent z-10 pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-24 md:w-64 bg-gradient-to-l from-neutral-900 to-transparent z-10 pointer-events-none"></div>

        <!-- Scrolling Track -->
        <div class="flex gap-8 animate-marquee w-max hover:[animation-play-state:paused] py-10">
            {
                allReviews.map((review) => (
                    <div class="relative w-[350px] md:w-[450px] p-8 bg-black/50 border border-white/5 rounded-none flex-shrink-0 group hover:border-luxury-gold/30 hover:z-50 transition-all duration-300 backdrop-blur-sm hover:shadow-2xl hover:shadow-luxury-gold/10">
                        <!-- Google Icon Watermark -->
                        <div class="absolute top-6 right-6 opacity-20 grayscale group-hover:grayscale-0 transition-all duration-300">
                             <svg class="w-6 h-6" viewBox="0 0 48 48">
                                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                                <path fill="none" d="M0 0h48v48H0z"/>
                            </svg>
                        </div>

                        <!-- Quote Icon -->
                        <div class="absolute -top-6 -left-2 text-8xl text-luxury-gold opacity-10 font-serif leading-none select-none">
                            “
                        </div>

                        <!-- Stars -->
                        <div class="flex gap-1 mb-6 text-luxury-gold relative z-10">
                            {Array.from({ length: review.data.rating }).map(() => (
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                </svg>
                            ))}
                        </div>

                        <!-- Text -->
                        <p class="text-neutral-300 text-lg leading-relaxed italic mb-8 relative z-10">
                            "{review.data.text}"
                        </p>

                        <!-- Author -->
                        <div class="flex items-center justify-between border-t border-white/10 pt-6 mt-auto">
                            <div>
                                <p class="text-white font-bold uppercase tracking-wider">
                                    {review.data.name}
                                </p>
                                <p class="text-xs text-neutral-500 uppercase tracking-widest mt-1">
                                    {review.data.service}
                                </p>
                            </div>
                            <span class="text-xs font-mono text-neutral-600">
                                {review.data.date}
                            </span>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
    
    <!-- CTA Button -->
    <div class="text-center">
        <a href="https://maps.google.com" target="_blank" class="inline-flex items-center gap-3 text-luxury-gold border border-luxury-gold px-8 py-4 uppercase tracking-widest font-bold hover:bg-luxury-gold hover:text-black transition-colors duration-300">
            <span>{lang === 'sk' ? 'Zobraziť všetky recenzie' : 'View all reviews'}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" x2="21" y1="14" y2="3"></line></svg>
        </a>
    </div>
</section>

<style>
    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); } 
        /* Move half way because list is tripled? No, if tripled, move 1/3. 
           Actually safe way is duplicing content and translating -50% of total width if doubled.
           Here we tripled so we can translate -33.33% or just create enough specific length.
           Let's refine: Use specific width calculations or simple -50% if content is exactly doubled.
           Current implementation: tripled list. 
           If we use typical marquee technique:
           [A B C] [A B C] 
           Move from 0 to -50% works perfectly.
        */
    }
    .animate-marquee {
        animation: marquee 40s linear infinite;
    }
</style>
