---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import heroImage from '../assets/hero.avif'
import gallery1 from '../assets/gallery/gallery1.webp'
import gallery2 from '../assets/gallery/gallery2.webp'
import gallery3 from '../assets/gallery/gallery3.webp'
import gallery4 from '../assets/gallery/gallery4.webp'
import gallery5 from '../assets/gallery/gallery5.webp'
import gallery6 from '../assets/gallery/gallery6.webp'
import ReviewMarquee from '../components/ReviewMarquee.astro';
import CTASection from '../components/CTASection.astro';

const services = await getCollection('services')
const barbers = await getCollection('barbers')

// Sort services by order
const sortedServices = services.sort((a, b) => a.data.order - b.data.order)
---

<Layout title="Barber Shop Bratislava | Luxury Cuts">
	<main>
		<!-- Hero Section -->
		<!-- Hero Section -->
		<section class="min-h-screen flex flex-col md:grid md:grid-cols-2">
			<!-- Hero Image (Left/Top) -->
			<div class="relative h-[70vh] md:h-screen w-full overflow-hidden group">
				<Image
					src={heroImage}
					alt="Barber Shop Hero"
					class="absolute inset-0 w-full h-full object-cover animate-slow-zoom"
					widths={[640, 768, 1024, 1280, 1600, 1920]}
					sizes="(max-width: 768px) 100vw, 50vw"
					loading="eager"
					fetchpriority="high"
				/>
				<div
					class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent md:bg-black/20"
				>
				</div>
                
                <!-- Mobile Title Overlay (Visible only on small screens) -->
				<div class="absolute bottom-24 left-0 w-full px-6 text-center md:hidden z-10">
					<h1 class="flex flex-col items-center font-black uppercase tracking-tighter leading-[0.85] text-white Drop-shadow-2xl">
                        <span class="text-6xl mb-1">Precision.</span>
                        <span class="text-6xl text-luxury-gold mb-1">Craft.</span>
                        <span class="text-6xl">Style.</span>
					</h1>
				</div>
			</div>

			<!-- Hero Content (Right/Bottom) -->
			<div class="flex flex-col justify-center px-6 pb-12 -mt-16 pt-16 rounded-t-[2.5rem] md:rounded-none md:mt-0 md:pt-20 md:p-20 bg-black relative z-20 text-center md:text-left shadow-[0_-10px_40px_rgba(0,0,0,0.8)]">
                <!-- Desktop Title -->
				<h1
					class="hidden md:flex flex-col font-black uppercase tracking-tighter leading-[0.85] mb-10 text-white"
				>
					<span class="text-[clamp(4rem,7vw,8rem)] animate-fade-in-up">Precision.</span>
					<span class="text-[clamp(4rem,7vw,8rem)] text-luxury-gold animate-fade-in-up delay-100 ml-16">Craft.</span>
					<span class="text-[clamp(4rem,7vw,8rem)] animate-fade-in-up delay-200">Style.</span>
				</h1>

				<p
					class="text-neutral-400 text-lg md:text-xl max-w-md mx-auto md:mx-0 mb-10 font-light leading-relaxed animate-fade-in-up delay-300"
				>
					Viac než len holičstvo. Miesto, kde sa tradícia stretáva s moderným životným štýlom. 
                    Dopraj si strih, ktorý hovorí za teba.
				</p>

				<div class="flex flex-col gap-8 animate-fade-in-up delay-500 items-center md:items-start">
                    <!-- Standard CTA Button -->
					<a
						href="https://www.bookio.com/sk"
						target="_blank"
						rel="noopener noreferrer"
						class="group relative inline-flex items-center justify-center px-8 py-4 bg-luxury-gold text-black font-black uppercase tracking-widest text-sm overflow-hidden transition-transform hover:scale-105 w-full md:w-fit"
					>
                        <span class="relative z-10 group-hover:text-black transition-colors">Rezervovať termín</span>
                        <div class="absolute inset-0 bg-white transform -translate-x-full group-hover:translate-x-0 transition-transform duration-300 ease-in-out"></div>
					</a>
                    
                    <!-- Styled Open Now Badge -->
                    <!-- Simple Open Now Indicator -->
					<div class="flex items-center gap-3 mt-2">
						<span class="relative flex h-3 w-3">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                        </span>
						<span class="text-neutral-400 text-xs font-bold uppercase tracking-widest">
                            Dnes Otvorené: 10:00 - 20:00
                        </span>
					</div>
				</div>
			</div>
		</section>

		<!-- Pricing Section -->
		<section
			id="cennik"
			class="py-24 px-6 bg-black border-t border-white/10"
		>
			<div class="max-w-7xl mx-auto">
				<h2
					class="text-6xl md:text-8xl font-black uppercase tracking-tighter mb-24 text-center text-white"
				>
					Cenník
				</h2>

				<!-- 3x3 Grid Layout -->
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{
						sortedServices.map((service, index) => {
							const tier = service.data.tier || 'junior';
							
							// Visual Styles per Tier
							const tierStyles = {
								master: 'bg-gradient-to-b from-neutral-900 to-black text-luxury-gold border border-luxury-gold/30 hover:border-luxury-gold hover:shadow-[0_0_30px_rgba(198,168,124,0.1)]',
								senior: 'bg-gradient-to-br from-luxury-gold to-[#9e8253] text-black border border-transparent shadow-lg',
								junior: 'bg-neutral-900 text-neutral-400 border border-white/5 hover:border-white/20'
							};

							const style = tierStyles[tier as keyof typeof tierStyles];
							const isSenior = tier === 'senior';

							return (
								<article
									class={`group relative flex flex-col justify-between p-6 lg:p-10 aspect-square transition-all duration-500 hover:-translate-y-2 reveal ${style} delay-${(index % 3) * 100} ${isSenior ? 'lg:scale-105 z-10' : 'scale-100'}`}
								>
									<!-- Background Texture for Master -->
									{tier === 'master' && (
										<div 
											class="absolute inset-0 opacity-[0.03] pointer-events-none mix-blend-overlay"
											style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"
										></div>
									)}

									<!-- Content -->
									<div class="relative flex flex-col h-full justify-between z-10">
										<div>
											<div class="flex justify-between items-start mb-2">
												<h3 class={`text-2xl lg:text-3xl font-black uppercase tracking-tighter ${isSenior ? 'text-black' : 'text-white'}`}>
													{service.data.title}
												</h3>
												{/* Icon/Badge could go here */}
											</div>
											
											<div class={`text-xs uppercase tracking-[0.2em] font-bold opacity-70 mb-8 ${isSenior ? 'text-black' : 'text-luxury-gold'}`}>
												{service.data.title.includes('Combo') ? 'Strih + Brada + Ritual' : service.data.title.includes('Brada') ? 'Úprava brady' : 'Kompletný strih'}
											</div>
										</div>

										<div class="flex flex-col items-center justify-center flex-grow py-4">
											<span class={`text-6xl md:text-7xl lg:text-[6rem] font-black tracking-tighter leading-none ${isSenior ? 'text-black' : 'text-white'}`}>
												{service.data.price}
											</span>
										</div>

										<div class={`w-full pt-6 border-t flex justify-between items-end ${isSenior ? 'border-black/20 text-black/80' : 'border-white/10 text-neutral-500'}`}>
											<span class="font-mono text-base">{service.data.duration}</span>
											<span class="text-xs uppercase tracking-widest font-bold">{tier}</span>
										</div>
									</div>
								</article>
							)
						})
					}
				</div>
			</div>
		</section>

		<!-- Social Proof / Gallery -->
		<section
			id="galeria"
			class="py-20 bg-black border-t border-white/5 overflow-hidden"
		>
			<div
				class="max-w-7xl mx-auto px-6 mb-12 flex justify-between items-end"
			>
				<h2
					class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white"
				>
					#BarberBA
				</h2>
				<a
					href="https://instagram.com"
					class="hidden md:block text-sm uppercase tracking-widest hover:text-luxury-gold transition-colors"
				>
					@barber.ba on Instagram
				</a>
			</div>

			<!-- Bento Grid Gallery -->
			<div
				class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[200px] md:auto-rows-[300px]"
			>
				<!-- 1. Large Item (2x2) -->
				<div
					class="col-span-2 row-span-2 group relative overflow-hidden bg-neutral-900 reveal zoom-in"
				>
					<Image
						src={gallery1}
						alt="Signature Cut"
						class="w-full h-full object-cover grayscale-0 md:grayscale md:group-hover:grayscale-0 transition-all duration-700 ease-out scale-100 group-hover:scale-105"
					/>
					<div
						class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center"
					>
						<span
							class="text-luxury-gold tracking-widest uppercase font-bold text-sm translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
							>Signature Cut</span
						>
					</div>
				</div>

				<!-- 2. Standard Item (Top Right 1) -->
				<div
					class="col-span-1 row-span-1 group relative overflow-hidden bg-neutral-900 reveal delay-100"
				>
					<Image
						src={gallery2}
						alt="Detail Work"
						class="w-full h-full object-cover grayscale-0 md:grayscale md:group-hover:grayscale-0 transition-all duration-700 ease-out scale-100 group-hover:scale-105"
					/>
				</div>

				<!-- 3. Standard Item (Top Right 2) -->
				<div
					class="col-span-1 row-span-1 group relative overflow-hidden bg-neutral-900 reveal delay-200"
				>
					<Image
						src={gallery3}
						alt="Hot Towel"
						class="w-full h-full object-cover grayscale-0 md:grayscale md:group-hover:grayscale-0 transition-all duration-700 ease-out scale-100 group-hover:scale-105"
					/>
				</div>

				<!-- 4. Wide Item (Middle Right) -->
				<div
					class="col-span-2 md:col-span-2 row-span-1 group relative overflow-hidden bg-neutral-900 reveal delay-200"
				>
					<Image
						src={gallery4}
						alt="Styling"
						class="w-full h-full object-cover grayscale-0 md:grayscale md:group-hover:grayscale-0 transition-all duration-700 ease-out scale-100 group-hover:scale-105"
					/>
				</div>

				<!-- 5. Wide Item (Bottom Left) -->
				<div
					class="col-span-2 md:col-span-2 row-span-1 group relative overflow-hidden bg-neutral-900 reveal delay-300"
				>
					<Image
						src={gallery5}
						alt="Barber Tools"
						class="w-full h-full object-cover grayscale-0 md:grayscale md:group-hover:grayscale-0 transition-all duration-700 ease-out scale-100 group-hover:scale-105"
					/>
				</div>

				<!-- 6. Wide Item (Bottom Right) -->
				<div
					class="col-span-2 md:col-span-2 row-span-1 group relative overflow-hidden bg-neutral-900 reveal delay-300"
				>
					<Image
						src={gallery6}
						alt="Atmosphere"
						class="w-full h-full object-cover grayscale-0 md:grayscale md:group-hover:grayscale-0 transition-all duration-700 ease-out scale-100 group-hover:scale-105"
					/>
				</div>
			</div>
		</section>

		<!-- Team Section -->
		<section id="nas-tim" class="py-20 px-6 bg-black border-t border-white/5">
			<div class="max-w-7xl mx-auto">
				<h2
					class="text-4xl md:text-6xl font-black uppercase tracking-tighter mb-16 text-center text-white"
				>
					Náš Tím
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{
						barbers.map((barber, index) => {
							const handle = barber.data.instagram 
								? '@' + barber.data.instagram.split('/').pop() 
								: '@barber';

							return (
							<div
								class={`group flex flex-col bg-neutral-900 border border-white/5 hover:border-luxury-gold/30 transition-all duration-500 reveal delay-${(index + 1) * 100} hover:-translate-y-2`}
							>
								<div class="aspect-[3/4] overflow-hidden relative">
									{barber.data.image ? (
										<Image
											src={barber.data.image}
											alt={barber.data.name}
											class="w-full h-full object-cover group-hover:grayscale-0 scale-100 group-hover:scale-105 transition-all duration-700 ease-out"
										/>
									) : (
										<div class="w-full h-full bg-neutral-800 flex items-center justify-center text-neutral-600">
											No Image
										</div>
									)}
									<div class="absolute inset-0 bg-gradient-to-t from-neutral-900 via-transparent to-transparent opacity-60" />
								</div>
								
								<div class="p-8 flex flex-col flex-grow relative">
									<!-- Content -->
									<div class="mb-6">
										<h3 class="text-3xl font-black uppercase tracking-tighter text-white mb-1">
											{barber.data.name}
										</h3>
										<p class="text-luxury-gold text-xs uppercase tracking-[0.2em] font-bold">
											{barber.data.role}
										</p>
									</div>

									<!-- Quote -->
									<blockquote class="relative mb-8">
										<span class="absolute -top-4 -left-2 text-6xl text-luxury-gold opacity-10 font-serif leading-none">“</span>
										<p class="text-neutral-400 text-sm italic leading-relaxed relative z-10 pl-4 border-l-2 border-luxury-gold/20">
											{barber.data.bio.replace(/^"|"$/g, '')}
										</p>
									</blockquote>

									<!-- Instagram (Bottom Aligned) -->
									{barber.data.instagram && (
										<a
											href={barber.data.instagram}
											target="_blank"
											aria-label={`Instagram: ${handle}`}
											class="mt-auto inline-flex items-center gap-3 text-sm font-bold uppercase tracking-widest text-neutral-500 hover:text-white transition-colors group/link"
										>
											<div class="w-8 h-8 rounded-full bg-neutral-800 flex items-center justify-center group-hover/link:bg-luxury-gold group-hover/link:text-black transition-colors">
												<svg
													xmlns="http://www.w3.org/2000/svg"
													width="14"
													height="14"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
													<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
													<line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
												</svg>
											</div>
											<span>{handle}</span>
										</a>
									)}
								</div>
							</div>
						)})
					}
				</div>
			</div>
		</section>

		<!-- Reviews Section -->
		<ReviewMarquee />

        <!-- CTA Section -->
        <CTASection />

		<!-- Contact / Location -->
		<section id="kontakt" class="py-20 px-6 bg-neutral-900 border-t border-white/5">
			<div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12">
				<div>
					<h2
						class="text-4xl font-bold text-luxury-gold uppercase tracking-tighter mb-8"
					>
						Kde nás nájdeš
					</h2>
					<p class="text-xl text-neutral-400 mb-8 font-light">
						Námestie slobody 1<br />
						811 06 Bratislava<br />
						Slovakia
					</p>

					<div class="space-y-4">
						<a
							href="tel:+421900000000"
							class="block text-2xl font-mono text-white hover:text-luxury-gold transition-colors"
						>
							+421 900 000 000
						</a>
						<a
							href="mailto:info@barber.ba"
							class="block text-xl text-neutral-500 hover:text-white transition-colors"
						>
							info@barber.ba
						</a>
					</div>
				</div>

				<div
					class="h-[300px] bg-neutral-800 relative grayscale hover:grayscale-0 transition-all duration-500"
				>
					<!-- Replace with real map embed or image link -->
					<iframe
						title="Mapa prevádzky Barber.ba"
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2661.889348981451!2d17.1097!3d48.1517!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x476c8942df520409%3A0x629f1234567890!2sN%C3%A1mestie%20slobody%2C%20Bratislava!5e0!3m2!1sen!2ssk!4v1620000000000!5m2!1sen!2ssk"
						width="100%"
						height="100%"
						style="border:0;"
						allowfullscreen=""
						loading="lazy"
						class="absolute inset-0 w-full h-full"></iframe>
				</div>
			</div>
		</section>
	</main>
</Layout>
